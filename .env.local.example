# Copia este fichero como .env.local y rellena con tus perfiles de ~/.aws/credentials
# .env.local NO se commitea al repositorio (está en .gitignore via *.local)

# Nombre del perfil en ~/.aws/credentials para cada entorno
DYNAMO_PROFILE_DESA=entornoDesa
DYNAMO_PROFILE_PRE=entornePre
DYNAMO_PROFILE_PRO=entornoPro

# Región AWS (por defecto eu-west-1)
# DYNAMO_REGION=eu-west-1
